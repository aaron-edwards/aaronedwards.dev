{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "trailingCommas": "es5",
      "semicolons": "asNeeded"
    }
  },
  "files": {
    "ignore": [
      ".turbo",
      "**/dist",
      "**/.next",
      "**/node_modules",
      "**/coverage"
    ]
  },
  "overrides": [
    {
      "include": ["tsconfig*.json"],
      "json": {
        "parser": {
          "allowComments": true
        }
      }
    }
  ]
}
